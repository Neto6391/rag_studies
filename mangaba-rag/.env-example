OPENROUTER_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=openai/gpt-4o-mini
# Estratégia de rerank: "cross_encoder" (default, rápido/grátis) ou "llm"
# (LLM-as-reranker via OpenRouter — entende o PT arcaico; +1 chamada por busca).
RERANK_STRATEGY=cross_encoder
REDIS_URL=redis://localhost:6379/0
CACHE_NAMESPACE=machado_mangaba
CACHE_TTL_SECONDS=3600
RETRIEVE_TOP_K=10
RERANK_TOP_K=5
GRAPH_PATH=data/knowledge_graph.gpickle
NODE2VEC_PATH=data/node2vec.npy
NODE2VEC_MAP_PATH=data/node2vec_ids.json
NODE2VEC_DIMENSIONS=64
NODE2VEC_WALK_LENGTH=20
NODE2VEC_NUM_WALKS=10
NODE2VEC_P=1.0
NODE2VEC_Q=0.5
